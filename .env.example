# Copy this file to .env (local dev), .env.main (prod VPS dir) or .env.dev (dev VPS dir).
# .env / .env.main / .env.dev are gitignored — never commit real secrets.

# Bare root domain — same value in .env.main AND .env.dev. Do NOT include a
# "dev." prefix here: docker-compose.dev.yml's build args and
# caddy/Caddyfile.dev already add it for you (darts.api.dev.${DOMAIN}). Set
# DOMAIN=dev.mydomain.com and you'll get darts.api.dev.dev.mydomain.com.
DOMAIN=mydomain.com

# Name of the external Docker network the host's existing Caddy instance is attached to.
# The backend container joins this network so Caddy can reverse-proxy to it by container name.
CADDY_NETWORK=caddy

POSTGRES_USER=dartscounter
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dartscounter
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

# Origins allowed to call the API from a browser (comma-separated). For
# .env.main/.env.dev, set this to the real dashboard/counter origins, e.g.
# https://darts.mydomain.com,https://darts.counter.mydomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Linked from notification messages ("voir toutes les stats").
DASHBOARD_URL=https://darts.mydomain.com

# Optional fallback webhook URLs, used only if no target has been configured
# via POST /webhooks yet (see README "Notifications"). Leave unset to manage
# webhooks entirely through the API instead.
GOOGLE_CHAT_WEBHOOK=
DISCORD_WEBHOOK_URL=

# Signs login tokens (JWT) — MUST be a real random secret in .env.main/.env.dev,
# e.g. generate one with `openssl rand -hex 32`. The app falls back to an
# obviously-insecure default if unset, which is fine for local dev only.
AUTH_SECRET_KEY=

# Public base URL of the API itself, used to turn uploaded avatar/flight image
# paths into absolute URLs the dashboard can render directly.
# .env.main -> https://darts.api.mydomain.com · .env.dev -> https://darts.api.dev.mydomain.com
PUBLIC_API_URL=https://darts.api.mydomain.com
