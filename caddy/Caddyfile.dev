# Sample Caddy config for the dev stack. Copy the relevant block into the VPS's
# existing Caddy instance — Caddy must be attached to the same external Docker
# network as this compose stack (see CADDY_NETWORK in .env.dev) to resolve
# containers by name.

dev.{$DOMAIN} {
    reverse_proxy dartscounter-dev-dashboard:80
}

counter.dev.{$DOMAIN} {
    reverse_proxy dartscounter-dev-counter:80
}

api.dev.{$DOMAIN} {
    reverse_proxy dartscounter-dev-backend:8000
}
